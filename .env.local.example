# Bazaar Supabase credentials
NEXT_PUBLIC_BAZAAR_SUPABASE_URL=https://your-bazaar-project.supabase.co
NEXT_PUBLIC_BAZAAR_SUPABASE_ANON_KEY=your-anon-key
BAZAAR_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
